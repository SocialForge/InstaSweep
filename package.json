        "css-loader": "^7.1.4",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.20.0",
        "sass": "^1.99.0",
        "sass-loader": "^16.0.7",
        "style-loader": "^4.0.0",
        "svg-inline-loader": "^0.8.2",
        "ts-loader": "^9.5.7",
        "typescript": "^6.0.2"
